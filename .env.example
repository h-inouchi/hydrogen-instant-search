# Hydrogen showcase environment variables.
#
# main (the public instant-search demo) runs on mock.shop and needs only
# SESSION_SECRET — member pricing stays dormant.
#
# To demo the headless MEMBER PRICE feature, point a SEPARATE preview deploy at
# a real store that has the Member Prices app installed (so the
# member_prices/rules shop metafield exists) and set the values below.

# Required everywhere.
SESSION_SECRET="change-me"

# --- mock.shop (default) ---
# Leave PUBLIC_STORE_DOMAIN unset (or "mock.shop") to use Shopify's public
# sample catalog with no token. Member pricing renders nothing in this mode.

# --- Real store (member-price preview) ---
# Storefront API (public token) + your myshopify domain.
# PUBLIC_STORE_DOMAIN="your-store.myshopify.com"
# PUBLIC_STOREFRONT_API_TOKEN="..."
# PUBLIC_STOREFRONT_ID="..."

# Customer Account API (from the Headless channel → Customer Account API).
# Register https://<your-preview>.workers.dev/account/authorize as a callback URI.
# PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID="shp_..."
# SHOP_ID="..."

# Admin API token — SERVER-ONLY SECRET, never PUBLIC_. Used only to look up the
# logged-in customer's tags (Customer Account API doesn't expose them). Create a
# custom app with the read_customers scope. Set via `wrangler secret put` in
# production; do NOT commit a real value.
# PRIVATE_ADMIN_API_TOKEN="shpat_..."
